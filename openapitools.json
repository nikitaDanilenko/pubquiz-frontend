{
  "$schema": "./node_modules/@openapitools/openapi-generator-cli/config.schema.json",
  "spaces": 2,
  "generator-cli": {
    "version": "7.4.0",
    "generators": {
      "elm": {
        "generatorName": "elm",
        "output": "src/Generated",
        "inputSpec": "${OPENAPI_URL}",
        "skipValidateSpec": true
      }
    }
  }
}

